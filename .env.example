# ─── LiveKit ───────────────────────────────────────────
# Run `livekit-server --dev` for local development
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_must_be_at_least_32_chars_long_xx

# ─── AI Providers ──────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPGRAM_API_KEY=...
ELEVEN_API_KEY=sk_...

# ─── Logging ───────────────────────────────────────────
LIVEKIT_LOG_LEVEL=warn
